# MongoDB connection (use database name taskforge in the URI path)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/taskforge

# Strong random secret for signing JWTs (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-to-a-long-random-string

# Optional: public site URL for redirects in production
# NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
